LANDING_DIR=sandals-motion
SHOP_NAME=Black Breeze
PRODUCT_NAME=Black Breeze Sandals
PRODUCT_PRICE=895
PRODUCT_OLD_PRICE=1899
PRODUCT_DESCRIPTION=women's black summer sandals with soft cushioned sole, perforated front strap, adjustable ankle strap, city and vacation style
PRODUCT_UPPER=eco-leather with perforation
PRODUCT_SOLE=soft cushioned platform for long walks
PRODUCT_BEST_FOR=summer city walks, vacations, dresses, jeans, and everyday warm weather
META_PIXEL_ID=2110562173060470
# Optional: enables server-side Meta Conversions API with deduplication by browser event_id.
# META_ACCESS_TOKEN=put_meta_conversions_api_token_here
# META_TEST_EVENT_CODE=TEST12345
NOVA_POSHTA_API_KEY=put_real_key_here
NP_SENDER_PHONE=380XXXXXXXXX
NP_SENDER_CITY_NAME=Одеса
NP_SENDER_WAREHOUSE=33448
# Optional only if the Nova Poshta account has several senders/warehouses and auto-detect picks the wrong one:
# NP_SENDER_CITY_REF=sender_city_ref_from_nova_poshta
# NP_SENDER_REF=sender_counterparty_ref
# NP_SENDER_ADDRESS_REF=sender_warehouse_or_address_ref
# NP_CONTACT_SENDER_REF=sender_contact_person_ref
NP_PAYER_TYPE=Recipient
NP_PAYMENT_METHOD=Cash
NP_SERVICE_TYPE=WarehouseWarehouse
NP_CARGO_TYPE=Parcel
NP_WEIGHT_KG=1
NP_VOLUME_GENERAL=0.002
NP_SEATS_AMOUNT=1
# Default Nova Poshta flat 3 kg box seat dimensions, in centimeters.
NP_SEAT_WIDTH_CM=24
NP_SEAT_LENGTH_CM=34
NP_SEAT_HEIGHT_CM=14.7
# Optional: prefix before product and size in the TTN description.
# NP_DESCRIPTION=Shoes
# Packaging is enabled by default with Nova Poshta flat 3 kg box.
NP_PACK_ENABLED=true
NP_PACK_REF=6acae69a-e177-4732-9935-acecf090b158
NP_COD_ENABLED=true
NP_SYNC_INTERVAL_MINUTES=30
# Monobank personal API: token from https://api.monobank.ua/
MONOBANK_TOKEN=put_personal_monobank_token_here
# 0 means default UAH card/account; set a specific account id only if needed.
MONOBANK_ACCOUNT_ID=0
MONOBANK_AUTO_SYNC=true
MONOBANK_SYNC_INTERVAL_MINUTES=5
MONOBANK_STARTUP_SYNC_DAYS=7
MONOBANK_INTERVAL_SYNC_DAYS=7
# Finance reports ignore older operations and begin at 26.05.2026 00:00 Kyiv time.
FINANCE_START_AT=2026-05-25T21:00:00.000Z
# Needed for live webhooks. Render usually provides RENDER_EXTERNAL_URL automatically.
MONOBANK_WEBHOOK_SECRET=put_long_random_secret_here
# APP_PUBLIC_URL=https://your-service.onrender.com
# Only these bank operations are imported into CRM.
MONOBANK_NP_KEYWORDS=нова пошта,новая почта,nova poshta,nova post,nova posta,novaposhta,novapost,nova pay,novapay,novaposta
MONOBANK_ADS_KEYWORDS=facebook,facebk,fb ads,fbpay,meta,meta platforms,instagram,google ads,tiktok,tik tok
# Optional comma-separated labels for automatic categorization.
MONOBANK_BUSINESS_KEYWORDS=постачальник,supplier,упаковка,packaging
MONOBANK_PERSONAL_KEYWORDS=таврія,rozetka,temu,київстар,kyivstar,farm,medicap,into-sana,jet.ua
