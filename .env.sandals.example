LANDING_DIR=sandals-motion
SHOP_NAME=Black Breeze
PRODUCT_NAME=Black Breeze Sandals
PRODUCT_PRICE=895
PRODUCT_OLD_PRICE=1899
PRODUCT_DESCRIPTION=women's black summer sandals with soft cushioned sole, perforated front strap, adjustable ankle strap, city and vacation style
PRODUCT_UPPER=eco-leather with perforation
PRODUCT_SOLE=soft cushioned platform for long walks
PRODUCT_BEST_FOR=summer city walks, vacations, dresses, jeans, and everyday warm weather
META_PIXEL_ID=2110562173060470
# Optional: enables server-side Meta Conversions API with deduplication by browser event_id.
# META_ACCESS_TOKEN=put_meta_conversions_api_token_here
# META_TEST_EVENT_CODE=TEST12345
BOT_TOKEN=put_telegram_bot_token_here
ADMIN_IDS=7996143460
SERVER_URL=https://your-main-web-service.onrender.com
API_KEY=put_same_api_key_on_server_and_bot_here
# Separate key for the partner CRM. Never give the bot/admin API_KEY to a partner.
PARTNER_CRM_API_KEY=put_generated_partner_crm_key_here
# Production bridge of Universal CRM (Next.js + Supabase; Apps Script is not used).
PARTNER_CRM_URL=https://www.to-pcrm.com/api/integrations/violet-motion/bridge
PARTNER_CRM_AUTO_SYNC=true
# Keep false: startup/cron reconcile linked orders but never imports/exports missing historical rows.
PARTNER_CRM_ALLOW_BACKFILL=false
PARTNER_CRM_SYNC_INTERVAL_MINUTES=5
PARTNER_CRM_TIMEOUT_MS=15000
# AI support answers common questions locally first, then uses Gemini when configured.
SUPPORT_AI_ENABLED=true
GEMINI_API_KEY=put_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
SUPPORT_AI_MAX_PER_SESSION=8
# One short Telegram summary is created only after this idle period.
SUPPORT_AI_IDLE_MINUTES=10
# Polling works only when exactly one bot process is running.
# For a Render bot web service, webhook mode avoids Telegram 409 getUpdates conflicts.
BOT_USE_WEBHOOK=false
# BOT_USE_WEBHOOK=true
# BOT_WEBHOOK_URL=https://your-bot-service.onrender.com
# BOT_WEBHOOK_SECRET=put_long_random_secret_here
BOT_API_TIMEOUT_MS=35000
# Keep false/empty on Render. A temporary Telegram 409 during deploy should not disable the bot.
BOT_STOP_ON_POLLING_CONFLICT=false
NOVA_POSHTA_API_KEY=put_real_key_here
NP_SENDER_PHONE=380XXXXXXXXX
NP_SENDER_CITY_NAME=Одеса
NP_SENDER_WAREHOUSE=33448
# Optional only if the Nova Poshta account has several senders/warehouses and auto-detect picks the wrong one:
# NP_SENDER_CITY_REF=sender_city_ref_from_nova_poshta
# NP_SENDER_REF=sender_counterparty_ref
# NP_SENDER_ADDRESS_REF=sender_warehouse_or_address_ref
# NP_CONTACT_SENDER_REF=sender_contact_person_ref
NP_PAYER_TYPE=Sender
NP_PAYMENT_METHOD=NonCash
NP_SERVICE_TYPE=WarehouseWarehouse
NP_CARGO_TYPE=Parcel
NP_WEIGHT_KG=2
NP_SEATS_AMOUNT=1
# Required by Nova Poshta for postomats and some warehouse shipments.
# These are dimensions of one packed seat/place.
NP_SEAT_WIDTH_CM=25
NP_SEAT_LENGTH_CM=35
NP_SEAT_HEIGHT_CM=15
# Optional override; by default calculated as width * length * height / 4000.
# NP_SEAT_VOLUMETRIC_WEIGHT_KG=3.28
# Optional: prefix before product and size in the TTN description.
# NP_DESCRIPTION=Shoes
# By default the same description is duplicated into Nova Poshta AdditionalInformation.
# NP_ADDITIONAL_INFORMATION=Shoes
# Payment control in Nova Poshta cabinet. This sends AfterpaymentOnGoodsCost.
NP_PAYMENT_CONTROL_ENABLED=true
# Extra amount added on top of every product price for Nova Poshta payment control.
NP_PAYMENT_CONTROL_EXTRA_UAH=140
# Legacy cash-on-delivery redelivery is disabled by default and should stay off for payment control.
NP_LEGACY_BACKWARD_DELIVERY_ENABLED=false
NP_AUTO_SYNC=true
NP_SYNC_INTERVAL_MINUTES=10
NP_SYNC_LIMIT=100
NP_SYNC_STARTUP_DELAY_MS=15000
NP_SYNC_AFTER_TTN_DELAY_MS=120000
NP_SYNC_AFTER_TTN_LIMIT=30
# Monobank personal API: token from https://api.monobank.ua/
MONOBANK_TOKEN=put_personal_monobank_token_here
# 0 means default UAH card/account; set a specific account id only if needed.
MONOBANK_ACCOUNT_ID=0
MONOBANK_AUTO_SYNC=true
MONOBANK_SYNC_INTERVAL_MINUTES=5
MONOBANK_STARTUP_SYNC_DAYS=7
MONOBANK_INTERVAL_SYNC_DAYS=7
# Finance reports ignore older operations and begin at 26.05.2026 00:00 Kyiv time.
FINANCE_START_AT=2026-05-25T21:00:00.000Z
# Needed for live webhooks. Render usually provides RENDER_EXTERNAL_URL automatically.
MONOBANK_WEBHOOK_SECRET=put_long_random_secret_here
# APP_PUBLIC_URL=https://your-service.onrender.com
# Only these bank operations are imported into CRM.
MONOBANK_NP_KEYWORDS=нова пошта,новая почта,nova poshta,nova post,nova posta,novaposhta,novapost,nova pay,novapay,novaposta
MONOBANK_ADS_KEYWORDS=facebook,facebk,fb ads,fbpay,meta,meta platforms,instagram,google ads,tiktok,tik tok
# Optional comma-separated labels for automatic categorization.
MONOBANK_BUSINESS_KEYWORDS=постачальник,supplier,упаковка,packaging
MONOBANK_PERSONAL_KEYWORDS=таврія,rozetka,temu,київстар,kyivstar,farm,medicap,into-sana,jet.ua
